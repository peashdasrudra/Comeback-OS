                          OMICS TYPES
                        </div>
                        <div className="flex flex-wrap gap-2">
                          {dataset.omics.map(omic => (
                            <span
                              key={omic}
                              className="px-2.5 py-1 bg-blue-500/10 border border-blue-400/20 rounded-lg text-[11px] text-blue-300"
